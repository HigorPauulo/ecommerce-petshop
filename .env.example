# Copie para .env e ajuste. O .env NAO deve ser versionado.

# Banco de dados (usado pelo docker-compose e pela aplicacao)
DB_NAME=ecommerce_petshop
DB_USERNAME=petshop
DB_PASSWORD=troque-esta-senha
DB_PORT=5432

# Conexao da aplicacao Spring
DB_URL=jdbc:postgresql://localhost:5432/ecommerce_petshop

# Porta do servidor da API
SERVER_PORT=8080

# JWT (use um segredo longo e aleatorio, no minimo 32 caracteres)
JWT_SECRET=troque-este-segredo-de-no-minimo-32-caracteres-para-hs256-ok
JWT_EXPIRATION=86400000
